{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://privatevtu-backend.onrender.com/api/v1",
        "EXPO_PUBLIC_SSL_PINNING_ENABLED": "true",
        "EXPO_PUBLIC_FIREBASE_APP_CHECK_ENABLED": "true"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://privatevtu-backend.onrender.com/api/v1",
        "EXPO_PUBLIC_SSL_PINNING_ENABLED": "true",
        "EXPO_PUBLIC_FIREBASE_APP_CHECK_ENABLED": "true"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
