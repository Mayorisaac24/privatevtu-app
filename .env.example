# Copy to .env and uncomment ONE EXPO_PUBLIC_API_BASE_URL line.
# Restart Expo after changing: npx expo start -c

# Local backend (iOS Simulator only — shares Mac localhost)
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# Physical device / Android emulator on same Wi‑Fi (replace with your Mac's LAN IP)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.251:4000/api/v1

# Live backend (Render)
# EXPO_PUBLIC_API_BASE_URL=https://privatevtu-backend.onrender.com/api/v1

# Mobile security (must match backend MOBILE_APP_SECRET in production)
# EXPO_PUBLIC_MOBILE_APP_SECRET=your-long-random-secret

# SSL pinning — enabled automatically on preview/production EAS builds
# EXPO_PUBLIC_SSL_PINNING_ENABLED=true
# EXPO_PUBLIC_SSL_PIN_SHA256=NnfKqDbhvUeabxD97xg7r9JvWoGY7BJjg8XThNJxVbk=,kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4=

# Firebase App Check (requires native EAS rebuild + Firebase console setup)
# EXPO_PUBLIC_FIREBASE_APP_CHECK_ENABLED=true
# EXPO_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=your-debug-token-from-firebase-console
